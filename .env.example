# Copy to .env and fill in your real keys. .env is gitignored.

# Optional — Alpha Vantage as backup for yfinance
ALPHA_VANTAGE_API_KEY=

# Optional — Polygon for higher-quality / intraday data (paid)
POLYGON_API_KEY=

# Hugging Face (for Kronos weights). Public model — token only needed for private repos.
HUGGINGFACE_TOKEN=

# Where DuckDB and parquet files are kept
TRADING_DATA_DIR=./data

# MLflow tracking URI (default: local file store)
MLFLOW_TRACKING_URI=./mlruns

# Default config
TRADING_CONFIG_PATH=./configs/mvp.yaml
