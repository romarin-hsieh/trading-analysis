# Copy to .env and fill in your real keys. .env is gitignored (verified: .env / .env.*
# are excluded; only this .env.example placeholder file is tracked).
# NEVER put real values in this file, in code, in configs, or in chat.

# ---- docs/24 data actions (all free tiers) ----

# Tiingo (action #7: delisted-stock rotation backfill -> GP final verdict)
TIINGO_API_KEY=

# Alpaca Market Data Basic (action #6: 2016+ minute-bar backfill)
# Use keys from a PAPER account (no funds; data access needs no trading permissions).
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Alpha Vantage (action #5: EARNINGS drip for consensus SUE; LISTING_STATUS)
ALPHA_VANTAGE_API_KEY=

# ThetaData (action #3): NO key goes here -- the free tier authenticates by logging
# into the local Theta Terminal app with your account; scripts talk to localhost.

# ---- existing / optional ----

# Optional — Massive (formerly Polygon) cross-validation source
POLYGON_API_KEY=

# Hugging Face (for Kronos weights). Public model — token only needed for private repos.
HUGGINGFACE_TOKEN=

# Where DuckDB and parquet files are kept
TRADING_DATA_DIR=./data

# MLflow tracking URI (default: local file store)
MLFLOW_TRACKING_URI=./mlruns

# Default config
TRADING_CONFIG_PATH=./configs/mvp.yaml
